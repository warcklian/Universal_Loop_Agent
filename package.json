{
  "name": "uagent",
  "version": "0.1.0",
  "description": "Universal agent config generator — auto-adapts to any project stack",
  "module": "src/cli.ts",
  "type": "module",
  "bin": {
    "uagent": "./src/cli.ts"
  },
  "private": true,
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile dist/uagent",
    "test": "bun test",
    "lint": "bun x tsc --noEmit",
    "typecheck": "bun x tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "yaml": "^2.9.0"
  }
}
